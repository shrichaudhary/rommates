{
  "name": "roommate-expense-manager",
  "version": "1.0.0",
  "description": "RoomSync – Real-time roommate expense manager powered by Firebase",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest --experimental-vm-modules",
    "test:e2e": "cypress open"
  },
  "dependencies": {
    "chart.js": "^4.4.3",
    "firebase": "^10.12.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "babel-jest": "^29.7.0",
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "cypress": "^13.12.0",
    "jest": "^29.7.0",
    "vite": "^5.3.1"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "babel": {
    "presets": [
      ["@babel/preset-env", { "targets": { "node": "current" } }]
    ]
  }
}
